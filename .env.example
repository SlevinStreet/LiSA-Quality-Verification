# LiSA VOC QC Platform — Environment Variables (EXAMPLE TEMPLATE)
# ─────────────────────────────────────────────────────────────────────────────
# ✅ This file IS safe to commit — it contains no real credentials.
#    To set up locally: copy this file to .env and fill in the real values.
#      cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# InsForge Backend URL (no trailing slash)
INSFORGE_BASE_URL=https://your-project.region.insforge.app

# InsForge Anonymous Key (public JWT — obtain from the InsForge dashboard)
INSFORGE_ANON_KEY=your-anon-key-here

# InsForge Service-Role / Admin API Key (server-side ONLY — NEVER expose in browser)
# Obtain from InsForge Dashboard → API Keys → Service Role Key
INSFORGE_API_KEY=your-service-role-key-here

# ─── Test / CI credentials (Node scripts only — never used in browser code) ───
# In production CI/CD (GitHub Actions), set these as repository Secrets:
#   Settings → Secrets and Variables → Actions → New repository secret
TEST_ADMIN_EMAIL=admin@yourdomain.com
TEST_ADMIN_PASSWORD=your-secure-test-password
